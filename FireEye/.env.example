# FireEye environment configuration
# Copy this to .env and fill in your values.

# --- OpenRouter / LLM ---
FIREEYE_OPENROUTER_API_KEY=sk-or-v1-your-key-here
FIREEYE_LLM_MODEL=google/gemini-3-flash-preview
FIREEYE_LLM_TEMPERATURE=0.0

# --- Local LLM (Ollama) ---
# Set FIREEYE_LLM_BACKEND=local to use a local Ollama model instead of OpenRouter.
# Install Ollama: curl -fsSL https://ollama.com/install.sh | sh
# Pull a model: ollama pull qwen2.5vl:7b
# FIREEYE_LLM_BACKEND=local
# FIREEYE_LOCAL_LLM_URL=http://localhost:11434
# FIREEYE_LOCAL_LLM_MODEL=qwen2.5vl:7b

# --- YOLO object detection ---
FIREEYE_YOLO_MODEL_NAME=fireeye_yolo11n_v4.pt
FIREEYE_YOLO_CONFIDENCE_THRESHOLD=0.25
# Device for YOLO inference: "auto" (detect GPU), "cpu", or "cuda"
FIREEYE_YOLO_DEVICE=auto

# --- Risk classification ---
FIREEYE_RISK_CONFIDENCE_THRESHOLD=0.5

# --- General ---
FIREEYE_DEBUG=false
